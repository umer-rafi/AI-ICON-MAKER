# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - keep API keys out of git
.env
.env.local
.env.development.local
.env.production.local
.env.test.local

# Allow the example env file to be committed (no secrets)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*
!.env.example
